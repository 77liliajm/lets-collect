{% extends 'base.html.twig' %}

{% block title %}Inscription — Let's Collect{% endblock %}

{% block body %}
<div style="max-width:420px; margin:60px auto; background:#fff; border:1px solid var(--lc-border); border-radius:16px; padding:2rem;">

    <h1 style="text-align:center; font-size:22px; font-weight:500; color:var(--lc-pink-dd); margin-bottom:0.5rem;">
        Rejoindre Let's Collect ✨
    </h1>
    <p style="text-align:center; font-size:13px; color:var(--lc-muted); margin-bottom:1.5rem;">
        Crée ton compte pour gérer ta collection
    </p>

    {% if error %}
        <div class="flash-error">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ path('app_register') }}">

        <div class="form-group">
            <label for="pseudo">Pseudo *</label>
            <input type="text" id="pseudo" name="pseudo" required
                   placeholder="ex: lilia_kpop">
        </div>

        <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required
                   placeholder="ton@email.fr">
        </div>

        <div class="form-group">
            <label for="password">Mot de passe *</label>
            <input type="password" id="password" name="password" required
                   placeholder="Au moins 6 caractères">
        </div>

        <div class="form-group">
            <label for="ville">Ville <span style="color:var(--lc-muted); font-weight:400;">(optionnel)</span></label>
            <input type="text" id="ville" name="ville"
                   placeholder="ex: Paris">
        </div>

        <button type="submit" class="btn-primary" style="width:100%; margin-top:0.5rem;">
            Créer mon compte
        </button>
    </form>

    <p style="text-align:center; margin-top:1rem; font-size:13px; color:var(--lc-muted);">
        Déjà un compte ?
        <a href="{{ path('app_login') }}" style="color:var(--lc-pink-d);">Se connecter</a>
    </p>

</div>
{% endblock %}
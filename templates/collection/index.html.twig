{% extends 'base.html.twig' %}

{% block title %}Ma collection — Let's Collect{% endblock %}

{% block body %}

<h1 class="section-header">Ma collection</h1>

{% if collection is empty %}
    <p style="color:var(--lc-muted); text-align:center; margin-top:3rem;">
        Ta collection est vide ! <a href="{{ path('app_recherche') }}">Recherche des cartes</a> pour commencer.
    </p>
{% else %}
    {% for groupeNom, albums in collection %}
        <div class="group-title">{{ groupeNom }}</div>

        {% for albumTitre, versions in albums %}
            <div class="album-title">{{ albumTitre }}</div>

            {% for versionNom, items in versions %}
                <div style="font-size:12px; color:var(--lc-muted); margin:0.5rem 0 0.5rem 2rem;">
                    {{ versionNom }}
                </div>
                <div class="card-grid" style="margin-bottom:1rem;">
                    {% for item in items %}
                    <div class="photocard">
                        <div class="photocard-img">
                            {% if item.photocard.image %}
                                <img src="{{ asset(item.photocard.image) }}"
                                     alt="{{ item.photocard.nomSet }}"
                                     style="width:100%; height:100%; object-fit:cover;">
                            {% else %}
                                🃏
                            {% endif %}
                        </div>
                        <div class="photocard-body">
                            <div class="photocard-name">
                                {% for idol in item.photocard.idols %}
                                    {{ idol.nomScene }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </div>
                            {% if item.quantite > 1 %}
                                <span class="badge-doublon">×{{ item.quantite }}</span>
                            {% endif %}
                            <div class="photocard-actions" style="margin-top:6px;">
                                <button class="heart-btn {% if item.photocard.wishlists|length > 0 %}active{% endif %}"
                                        data-id="{{ item.photocard.id }}">
                                    {% if item.photocard.wishlists|length > 0 %}♥{% else %}♡{% endif %}
                                </button>
                                <div class="counter">
                                    <button class="btn-minus" data-id="{{ item.photocard.id }}">−</button>
                                    <span class="count" id="count-{{ item.photocard.id }}">{{ item.quantite }}</span>
                                    <button class="btn-plus" data-id="{{ item.photocard.id }}">+</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% endfor %}
        {% endfor %}
    {% endfor %}
{% endif %}

{% if doublons is not empty %}
    <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--lc-border);">
        <h2 class="section-header">✨ Mes doublons</h2>
        <p style="font-size:13px; color:var(--lc-muted); margin-bottom:1rem;">
            Ces cartes sont disponibles pour l'échange !
        </p>
        <div class="card-grid">
            {% for item in doublons %}
            <div class="photocard">
                <div class="photocard-img">
                    {% if item.photocard.image %}
                        <img src="{{ asset(item.photocard.image) }}"
                             alt="{{ item.photocard.nomSet }}"
                             style="width:100%; height:100%; object-fit:cover;">
                    {% else %}
                        🃏
                    {% endif %}
                </div>
                <div class="photocard-body">
                    <div class="photocard-name">{{ item.photocard.nomSet }}</div>
                    <span class="badge-doublon">×{{ item.quantite }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
{% endif %}

{% endblock %}